%% gRPC client stub generation for the reckon-gateway protos
%% vendored under priv/proto. Runs as part of `rebar3 compile' via
%% the grpcbox_plugin declared at the umbrella root.
{provider_hooks, [
    {pre,  [{compile, {grpc, gen}}]},
    {post, [{clean,   {grpc, clean}}]}
]}.

{grpc, [
    {protos, "priv/proto"},
    {out_dir, "src"},
    {type, "client"},
    {gpb_opts, [
        {module_name_suffix, "_pb"},
        %% gpb resolves include paths relative to the project root
        %% (not the app dir), so spell out the full path.
        {i, "apps/reckon_e2e_grpc/priv/proto"},
        use_packages,
        maps,
        strings_as_binaries
    ]}
]}.
