{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

%% Pinned versions. Bump deliberately, document in CHANGELOG.
{deps, [
    {mem_evoq,     "0.1.2"},
    {reckon_evoq,  "2.1.1"},
    {reckon_db,    "2.1.1"},
    {evoq,         "1.15.0"},
    {reckon_gater, "2.1.0"},
    %% gRPC client for the clustered facade. Stubs are generated from
    %% priv/proto/*.proto (vendored copies of reckon-gateway's protos)
    %% via the grpcbox_plugin during `rebar3 compile'.
    {grpcbox,      "0.17.1"}
]}.

%% gRPC stub generation. Plugin runs as part of compile.
{plugins, [
    {grpcbox_plugin, "0.9.0"}
]}.

%% gRPC stub generation config lives in apps/reckon_e2e_grpc/rebar.config
%% — the plugin resolves paths relative to each app's directory.

%% Umbrella — each torture axis is an app under apps/.
{project_apps, [
    integrity_torture,
    adapter_swap_torture,
    reckon_e2e_grpc,
    multi_node_torture
]}.

{shell, [
    {apps, [mem_evoq, integrity_torture]}
]}.

{profiles, [
    {test, [
        {deps, [
            {proper, "1.4.0"}
        ]},
        {erl_opts, [debug_info, nowarn_export_all]}
    ]}
]}.

%% CT is the primary runner — scenarios take real time and want
%% per-testcase isolation. EUnit is reserved for tiny helper-module
%% checks within each torture app.
{ct_opts, [
    {dir, ["apps/integrity_torture/test",
           "apps/adapter_swap_torture/test",
           "apps/multi_node_torture/test"]}
]}.

{eunit_opts, [verbose]}.

{cover_enabled, true}.

{dialyzer, [
    {warnings, [unknown, unmatched_returns, error_handling]},
    {plt_apps, top_level_deps}
]}.
