{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

%% Pinned versions. Bump deliberately, document in CHANGELOG.
{deps, [
    {mem_evoq,     "0.1.1"},
    {evoq,         "1.15.0"},
    {reckon_gater, "2.1.0"}
]}.

%% Umbrella — each torture axis is an app under apps/.
{project_apps, [
    integrity_torture
]}.

{shell, [
    {apps, [mem_evoq, integrity_torture]}
]}.

{profiles, [
    {test, [
        {deps, [
            {proper, "1.4.0"}
        ]},
        {erl_opts, [debug_info, nowarn_export_all]}
    ]}
]}.

%% CT is the primary runner — scenarios take real time and want
%% per-testcase isolation. EUnit is reserved for tiny helper-module
%% checks within each torture app.
{ct_opts, [
    {dir, "apps/integrity_torture/test"}
]}.

{eunit_opts, [verbose]}.

{cover_enabled, true}.

{dialyzer, [
    {warnings, [unknown, unmatched_returns, error_handling]},
    {plt_apps, top_level_deps}
]}.
